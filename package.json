{
  "name": "prime-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "node --env-file=.env.local db/migrate.ts",
    "db:seed": "node --env-file=.env.local db/seed-dev.ts",
    "db:seed:admin": "node --env-file=.env.local db/seed-admin.ts",
    "test:db:setup": "createdb prime_portal_test 2>/dev/null; DATABASE_URL_MIGRATOR=postgres://$USER@localhost:5432/prime_portal_test NODE_ENV=development node db/migrate.ts",
    "pretest": "npm run test:db:setup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "framer-motion": "^12.42.0",
    "html-to-image": "^1.11.13",
    "jsbarcode": "^3.12.3",
    "next": "16.2.9",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.7.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
